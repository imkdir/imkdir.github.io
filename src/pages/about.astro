---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About">
    <h1
        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; color: #5f6368; margin-bottom: 3rem;"
    >
        Index / About
    </h1>

    <article style="max-width: 600px;">
        <div
            class="about-content"
            style="font-size: 1.05rem; line-height: 1.7; color: #e8eaed; margin-bottom: 4rem;"
        >
            <div style="display: flex; align-items: flex-start; gap: 40px">
            <img src="https://images.gr-assets.com/users/1670991435p6/53454089.jpg" width="120"/>
            <div>
                <p>
                    I write apps both for work and passion, reading classics and
                    philosophy for good, watching films to live more.
                </p>
                <p>An avid collector of physical beauties:</p>
                <ul>
                    <li>Rare and fine books from the past</li>
                    <li>Criterion Blu-rays in the present</li>
                    <li>Things on desk:
                        <ul>
                            <li>MacBook Pro M1</li>
                            <li>Fellow Ode Grinder</li>
                            <li>HHKB Pro Hybrid Type-S</li>
                            <li>HomePod Studio</li>
                            <li>Typewriter</li>
                            <li>Projector</li>
                        </ul>
                    </li>
                </ul>
            </div>
            </div>
        </div>
    </article>

    <div style="display: flex; gap: 40px; border-top: 1px solid #1f2023; padding-top: 2rem;">

        <a href="mailto:hihengd@gmail.com" class="social-link gmail">
            <img src="/gmail.svg" width="18" height="18" alt="Gmail" />
        </a>

        <a href="https://www.github.com/imkdir" target="_blank" class="social-link github" >
            <img src="/github.svg" width="18.35" height="18" alt="GitHub" />
        </a>

        <a href="https://www.instagram.com/_rmdir" target="_blank" class="social-link instagram" >
            <img src="/instagram.svg" width="18" height="18" alt="GitHub" />
        </a>

        <a href="https://www.goodreads.com/imkdir" target="_blank" class="social-link goodreads" >
            <img src="/goodreads.svg" width="80" height="20" alt="Goodreads" />
        </a>

        <a href="https://letterboxd.com/imkdir" target="_blank" class="social-link letterboxd" >
            <img src="/letterboxd.svg" width="114" height="12" alt="Letterboxd" />
        </a>

    </div>
</BaseLayout>

<style>
    .social-link {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        transition: transform 0.1s ease;
    }

    .social-link:active {
        transform: translateX(4px);
    }

    /* Brand Specific Styling */
    .gmail {
        color: #ea4335;
    }
    .letterboxd {
        color: #ff8000;
    }
    .goodreads {
        color: #754f44;
    }

    /* Muted initial state for icons */
    .social-link svg {
        opacity: 0.7;
        transition: opacity 0.2s ease;
    }

    .social-link:hover svg {
        opacity: 1;
    }

    .social-link span {
        filter: brightness(0.9);
    }

    .social-link:hover span {
        text-decoration: underline;
        filter: brightness(1.2);
    }
</dstyle>
