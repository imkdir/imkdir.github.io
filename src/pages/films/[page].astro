---
import { getCollection } from "astro:content";
import type { PaginateFunction } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import EntryList from "../../components/EntryList.astro";

export async function getStaticPaths({
    paginate,
}: {
    paginate: PaginateFunction;
}) {
    const allFilms = await getCollection("films");
    const sorted = allFilms.sort(
        (a, b) =>
            (b.data.date_watched?.valueOf() ?? 0) -
            (a.data.date_watched?.valueOf() ?? 0),
    );
    return paginate(sorted, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout title="Cinema">
    <h1
        style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; color: #5f6368; margin-bottom: 2rem;"
    >
        Archive / Cinema
    </h1>

    <EntryList page={page} collectionPath="films" />
</BaseLayout>
